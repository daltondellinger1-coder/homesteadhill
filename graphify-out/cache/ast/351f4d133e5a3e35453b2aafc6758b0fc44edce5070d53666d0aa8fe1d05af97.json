"L326"}, {"caller_nid": "components_bookingform_bookingform", "callee": "format", "is_member_call": false, "source_file": "/home/dalton/projects/homesteadhill/src/components/BookingForm.tsx", "source_location": "L333"}, {"caller_nid": "components_bookingform_bookingform", "callee": "cn", "is_member_call": false, "source_file": "/home/dalton/projects/homesteadhill/src/components/BookingForm.tsx", "source_location": "L361"}, {"caller_nid": "components_bookingform_bookingform", "callee": "format", "is_member_call": false, "source_file": "/home/dalton/projects/homesteadhill/src/components/BookingForm.tsx", "source_location": "L368"}, {"caller_nid": "components_bookingform_bookingform", "callee": "(() => {\n        const nights = Math.ceil((checkOutDate.getTime() - checkInDate.getTime()) / (1000 * 60 * 60 * 24));\n        const selectedUnit = units.find(u => u.id === formData.unit);\n        const pricing = selectedUnit ? calculatePricing(selectedUnit.monthlyPrice, nights, selectedUnit.type) : null;\n        \n        return (\n          <div className=\"bg-primary/5 p-4 rounded-lg space-y-3\">\n            <div className=\"flex items-center gap-2 text-sm text-primary\">\n              <CheckCircle className=\"w-4 h-4\" />\n              <span>\n                {format(checkInDate, \"MMM d, yyyy\")} \u2192 {format(checkOutDate, \"MMM d, yyyy\")} \n                {\" \"}({nights} night{nights !== 1 ? 's' : ''})\n              </span>\n            </div>\n            \n            {pricing && selectedUnit && (\n              <div className=\"border-t border-primary/20 pt-3 space-y-2\">\n                <div className=\"flex items-center justify-between text-sm\">\n                  <div className=\"flex items-center gap-2 text-muted-foreground\">\n                    <DollarSign className=\"w-4 h-4\" />\n                    <span>\n                      {pricing.rateType === \"monthly\" && \"Monthly rate\"}\n                      {pricing.rateType === \"weekly\" && \"Weekly rate\"}\n                      {pricing.rateType === \"nightly\" && \"Nightly rate\"}\n                      {pricing.rateType === \"minimum\" && `Minimum stay (3 nights)`}\n                      {\" \u00b7 \"}${pricing.perNight}/night\n                    </span>\n                  </div>\n                  <div className=\"text-muted-foreground\">\n                    ${pricing.subtotal.toLocaleString()}\n                  </div>\n                </div>\n                <div className=\"flex items-center justify-between pt-2 border-t border-primary/10\">\n                  <span className=\"font-medium\">Estimated Total</span>\n                  <div className=\"text-right\">\n                    <div className=\"text-xl font-semibold text-primary\">\n                      ${pricing.total.toLocaleString()}\n                    </div>\n                  </div>\n                </div>\n                {nights >= 30 && (\n                  <div className=\"mt-2 space-y-1\">\n                    <p className=\"text-xs text-primary\">\n                      \ud83c\udf89 You qualify for our best monthly rate!\n                    </p>\n                    <p className=\"text-xs text-muted-foreground\">\n                      \ud83d\udccb A rental application will be required for stays of 30+ nights. You'll be redirected to complete it after submitting your booking request.\n                    </p>\n                  </div>\n                )}\n                {nights >= 7 && nights < 30 && (\n                  <p className=\"text-xs text-primary mt-2\">\n                    \ud83d\udca1 Stay 30+ nights for our best monthly rate!\n                  </p>\n                )}\n                {nights < 3 && (\n                  <p className=\"text-xs text-muted-foreground mt-2\">\n                    Note: Minimum stay is 3 nights. Price shown for 3 nights.\n                  </p>\n                )}\n              </div>\n            )}\n          </div>\n        );\n      })", "is_member_call": false, "source_file": "/home/dalton/projects/homesteadhill/src/components/BookingForm.tsx", "source_location": "L408"}]}